# agenttalk — environment config
# Copy to .env and fill in values

# Butler OpenClaw gateway URL (loopback on the host machine)
BUTLER_GATEWAY_URL=http://127.0.0.1:18789

# Gateway password (from openclaw.json gateway.auth.password)
BUTLER_GATEWAY_PASSWORD=your_gateway_password_here

# Butler agent target (leave as-is unless you want a specific agent)
BUTLER_MODEL=openclaw/default

# HTTP server settings (when running in http mode)
AGENTTALK_HOST=0.0.0.0
AGENTTALK_PORT=3741

# Optional: protect this MCP's HTTP surface with an API key
# Remote agents must send: Authorization: Bearer <this key>
AGENTTALK_API_KEY=

# Optional reliability/dev settings
BUTLER_TIMEOUT_MS=60000
AGENTTALK_SESSION_TTL_MS=3600000
AGENTTALK_MAX_SESSIONS=250
AGENTTALK_DEBUG=0

# Local testing without the real Butler gateway
AGENTTALK_MOCK_BUTLER=0
